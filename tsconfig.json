{
  "extends": "@kalink-ui/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/components/*": ["components/*"],
      "@/slices/*": ["slices/*"],
      "@/style/*": ["style/*"],
      "@/styles/*": ["styles/*"],
      "@/types/*": ["types/*"]
    },
    "allowJs": true,
    "esModuleInterop": true,
    "lib": ["esnext", "DOM", "DOM.Iterable"]
  },
  "include": ["next-env.d.ts", ".next/types/**/*.ts", "**/*.ts", "**/*.tsx"],
  "exclude": [
    "node_modules",
    "**/*.stories.tsx",
    "node_modules/.pnpm/**/*",
    ".next/**/*"
  ]
}
